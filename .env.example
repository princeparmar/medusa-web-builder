# Database (use 5433 when running postgres via docker-compose — avoids local postgres on 5432)
DATABASE_URL=postgresql://mwb:mwb@localhost:5433/medusa_web_builder

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Email (Mailpit locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@medusa-web-builder.local

# GitHub App (medusa-storefronts org) — required to create storefront-{uuid} repos
# 1. Create a GitHub App: https://github.com/organizations/medusa-storefronts/settings/apps
# 2. Permissions: Administration (R/W), Contents (R/W), Metadata (R), Actions (R), Workflows (R)
# 3. Install the app on the medusa-storefronts organization
# 4. Paste App ID and download/generate a private key (PEM). For Docker, use \n for newlines in one line:
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_ORG=medusa-storefronts

# Workspace & deploy
WORKSPACE_ROOT=./workspaces
# Local pnpm dev: deploy stub or k8s agent on host
DEPLOY_WEBHOOK_URL=http://localhost:9090/deploy
# Docker compose worker uses http://deploy-stub:9090/deploy automatically
ENCRYPTION_KEY=change-me-32-char-minimum-key!!

# Registry (storefront-components + medusa-plugins)
STOREFRONT_COMPONENTS_GITHUB=https://github.com/pradip1995/storefront-components
STOREFRONT_COMPONENTS_PATH=/Users/pradipparmar/git/personal/storefront-components
MEDUSA_PLUGINS_GITHUB=https://github.com/SmartByteLabs/medusa-plugins
MEDUSA_PLUGINS_PATH=/Users/pradipparmar/git/ecommerce/medusa-plugins
