# Database (use host port below when postgres runs via docker-compose)
DATABASE_URL=postgresql://mwb:mwb@localhost:5433/medusa_web_builder

# Redis (6380 when using docker-compose — avoids local redis on 6379)
REDIS_URL=redis://localhost:6380

# Docker compose host port overrides (optional)
MWB_WEB_PORT=3100
MWB_POSTGRES_PORT=5433
MWB_REDIS_PORT=6380
MWB_MAILPIT_UI_PORT=8125
MWB_MAILPIT_SMTP_PORT=1125
MWB_DEPLOY_STUB_PORT=9190

# Auth — use 3000 for `pnpm dev:web` on the host; Docker web sets NEXTAUTH_URL from MWB_WEB_PORT automatically
AUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Email (Mailpit locally — UI on 8125 when using docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1125
SMTP_FROM=noreply@medusa-web-builder.local
NEXT_PUBLIC_MAILPIT_URL=http://localhost:8125

# GitHub App (medusa-storefronts org) — required to create storefront-{uuid} repos
# 1. Create a GitHub App: https://github.com/organizations/medusa-storefronts/settings/apps
# 2. Permissions: Administration (R/W), Contents (R/W), Metadata (R), Actions (R), Workflows (R)
# 3. Install the app on the medusa-storefronts organization
# 4. Paste App ID and download/generate a private key (PEM). For Docker, use \n for newlines in one line:
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_ORG=medusa-storefronts

# Shops workspace — scaffolded projects land in monorepo shops/ (relative to medusa-web-builder/)
WORKSPACE_ROOT=../shops
# Optional: GitHub release webhook target (local stub when using docker compose)
DEPLOY_WEBHOOK_URL=http://localhost:9190/deploy
ENCRYPTION_KEY=change-me-32-char-minimum-key!!

# Registry (GitHub import for seed; manage sections/plugins in admin panel)
STOREFRONT_COMPONENTS_GITHUB=https://github.com/pradip1995/storefront-components
MEDUSA_PLUGINS_GITHUB=https://github.com/SmartByteLabs/medusa-plugins
MEDUSA_PLUGINS_PATH=/Users/pradipparmar/git/ecommerce/medusa-plugins

# Ecosystem publish workflows (pnpm publish:ecosystem)
FRAMEWORK_REPO=SmartByteLabs/storefront-framework
COMPONENTS_REPO=princeparmar/storefront-components
PLUGINS_REPO=SmartByteLabs/medusa-plugins
STOREFRONT_FRAMEWORK_PATH=/Users/pradipparmar/git/ecommerce/storefront-framework
